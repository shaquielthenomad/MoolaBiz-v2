# ─── Hub (apps/hub) ─────────────────────────────────────────────────────────
# Coolify / Docker provisioning
COOLIFY_API_URL=https://coolify.yourdomain.com/api/v1
COOLIFY_API_TOKEN=your-coolify-api-token
COOLIFY_SERVER_UUID=your-server-uuid
COOLIFY_PROJECT_UUID=your-project-uuid

# Hub Supabase (master tenant registry)
NEXT_PUBLIC_SUPABASE_URL=https://your-hub-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-hub-service-role-key

# Hub auth
HUB_API_SECRET=a-random-secret-for-provision-api

# ─── Bot (apps/bot) — set per-tenant ─────────────────────────────────────────
# Ollama (runs in same docker-compose)
OLLAMA_BASE_URL=http://ollama:11434

# Lelapa AI (VulaVula)
LELAPA_API_KEY=your-lelapa-api-key

# WhatsApp Cloud API (per-tenant)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=a-random-secret-you-choose

# Supabase (per-tenant)
NEXT_PUBLIC_SUPABASE_URL=https://your-tenant.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-tenant-service-role-key

# Cron security
CRON_SECRET=a-random-secret-for-cron-routes

# Admin dashboard
ADMIN_PASSWORD=changeme

# Devil's Advocate
ADVOCATE_API_KEY=your-secret-key-here

# Payments — per-tenant, pick one or more
YOCO_SECRET_KEY=sk_live_...
YOCO_WEBHOOK_SECRET=whsec_...
OZOW_SITE_CODE=your-site-code
OZOW_API_KEY=your-api-key
OZOW_PRIVATE_KEY=your-private-key
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYFAST_SANDBOX=true
NEXT_PUBLIC_APP_URL=https://your-bot.yourdomain.com
PAYMENTS_API_KEY=your-secret-key-here
